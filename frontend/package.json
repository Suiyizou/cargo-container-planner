{
  "name": "cargo-container-planner-frontend",
  "version": "0.2.0",
  "description": "货代装箱体积规划系统客户端",
  "author": "Suiyizou",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5177",
    "build": "npm run i18n:scan && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "i18n:scan": "node scripts/check-i18n-hardcoded.js",
    "i18n:baseline": "node scripts/check-i18n-hardcoded.js --write-baseline",
    "test:loaded-pallet-import": "node scripts/check-loaded-pallet-import.js",
    "test:irregular-pallet-import": "node scripts/check-irregular-pallet-import.js",
    "test:packing-single-layer-row-fill": "node scripts/check-packing-single-layer-row-fill.js",
    "test:packing-pallet-gap": "node scripts/check-packing-pallet-gap.js",
    "desktop:preview": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "element-plus": "^2.14.2",
    "three": "^0.180.0",
    "vite": "^5.4.19",
    "vue": "^3.5.17",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.cargo.container.planner",
    "productName": "货代装箱体积规划系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-setup.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "货代装箱体积规划系统"
    }
  }
}
