FRONTEND_PORT=80
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8080
MYSQL_BIND_ADDRESS=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cargo_planner
MYSQL_USER=cargo_planner
MYSQL_PASSWORD=cargo_planner_pwd
MYSQL_ROOT_PASSWORD=cargo_root_pwd
APP_DEVICE_LIMIT_PER_USER=5
APP_CUSTOMER_SESSION_HOURS=24
# First-start only: set all four values explicitly, start once, then disable and
# remove the password from .env. No fixed administrator is created by default.
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_USERNAME=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_DISPLAY_NAME=System Administrator
SPRING_AI_CHAT_MODEL=none
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.deepseek.com
SPRING_AI_OPENAI_MODEL=deepseek-v4-flash
EXCEL_AGENT_BATCH_CONCURRENCY=3
APP_WORKSPACE_FILE_RETENTION=14d
APP_WORKSPACE_FILE_CLEANUP_INTERVAL_MS=3600000
APP_WORKSPACE_FILE_MAX_SIZE_BYTES=83886080
APP_TRACKING_ADAPTER_BASE_URL=http://tracking:3000
APP_TRACKING_CACHE_TTL=15m
APP_TRACKING_CONNECT_TIMEOUT=5s
APP_TRACKING_READ_TIMEOUT=90s
SHIPMENT_FILE_HOST_PATH=./data/shipment-files
APP_SHIPMENT_FILE_MAX_SIZE_BYTES=83886080
APP_SHIPMENT_FILE_MAX_FILES_PER_SHIPMENT=200
APP_SHIPMENT_FILE_MAX_BYTES_PER_SHIPMENT=2147483648
APP_SHIPMENT_FILE_MAX_BYTES_PER_CUSTOMER=5368709120
APP_SHIPMENT_FILE_MIN_FREE_SPACE_BYTES=1073741824
APP_SHIPMENT_FILE_ALLOWED_EXTENSIONS=pdf,xlsx,xls,csv,doc,docx,jpg,jpeg,png,txt
VITE_TRACKING_WORKBENCH_URL=/tracking/
VITE_TRACKING_DEV_TARGET=http://127.0.0.1:3000
CHANNEL_C_MONITOR_ENABLED=true
PLAYWRIGHT_MAX_CONCURRENCY=2
PLAYWRIGHT_QUEUE_LIMIT=8
PLAYWRIGHT_QUEUE_TIMEOUT_MS=15000
